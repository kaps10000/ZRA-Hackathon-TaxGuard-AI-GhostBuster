# Server Configuration
NODE_ENV=development
PORT=3005
API_BASE_URL=http://localhost:3000

# Database Configuration
DB_HOST=localhost
DB_PORT=5432
DB_NAME=whistlepro
DB_USER=postgres
DB_PASSWORD=postgres

# JWT Configuration
JWT_SECRET=your-super-secret-jwt-key-min-32-chars-change-this-in-production
JWT_EXPIRES_IN=24h
JWT_REFRESH_EXPIRES_IN=7d

# Encryption Configuration
ENCRYPTION_KEY=your-32-character-encryption-key-change-this-in-production
ENCRYPTION_ALGORITHM=aes-256-gcm

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100
REPORT_RATE_LIMIT_MAX=5

# File Upload
MAX_FILE_SIZE=10485760
ALLOWED_FILE_TYPES=pdf,jpg,jpeg,png,doc,docx

# Security
CORS_ORIGIN=http://localhost:3001
BCRYPT_SALT_ROUNDS=12
IP_HASH_SECRET=your-ip-hashing-secret-key-change-this

# Logging
LOG_LEVEL=info
LOG_FILE=logs/app.log

# Blockchain Integration (Future)
BLOCKCHAIN_ENABLED=false
BLOCKCHAIN_API_URL=http://localhost:8080