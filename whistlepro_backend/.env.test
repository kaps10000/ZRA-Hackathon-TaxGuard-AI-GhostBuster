# Test Environment Configuration
NODE_ENV=test
PORT=3999
API_BASE_URL=http://localhost:3999

# Test Database
DB_HOST=localhost
DB_PORT=5432
DB_NAME=whistlepro_test
DB_USER=postgres
DB_PASSWORD=postgres

# JWT (Test keys)
JWT_SECRET=test-jwt-secret-key-for-testing-only-32-chars-minimum
JWT_EXPIRES_IN=24h
JWT_REFRESH_EXPIRES_IN=7d

# Encryption (Test key)
ENCRYPTION_KEY=test-encryption-key-32-chars-min
ENCRYPTION_ALGORITHM=aes-256-gcm

# Rate Limiting (Disabled for tests)
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=1000
REPORT_RATE_LIMIT_MAX=100

# Security
CORS_ORIGIN=http://localhost:3001
BCRYPT_SALT_ROUNDS=10
IP_HASH_SECRET=test-ip-hashing-secret

# Logging
LOG_LEVEL=error
LOG_FILE=logs/test.log
