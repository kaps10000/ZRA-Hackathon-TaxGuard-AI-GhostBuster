{
  "info": {
    "name": "ZRA TaxGuard - COMPLETE API Collection",
    "description": "Complete API collection for ALL ZRA TaxGuard services:\n\n1. OCR AI Service (Port 8000) - Document processing\n2. Blockchain API (Port 3001) - Event management\n3. OCR Backend (Port 5000) - Legacy/backup service\n\nAll file upload endpoints require POST with multipart/form-data.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "OCR AI Service (Port 8000)",
      "description": "FastAPI-based OCR and document verification service",
      "item": [
        {
          "name": "Health Check",
          "request": {
            "method": "GET",
            "header": [],
            "url": "http://localhost:8000/health"
          }
        },
        {
          "name": "Process OCR",
          "request": {
            "method": "POST",
            "body": {
              "mode": "formdata",
              "formdata": [
                {"key": "file", "type": "file", "src": ""},
                {"key": "preprocess", "value": "true", "type": "text"},
                {"key": "language", "value": "eng", "type": "text"}
              ]
            },
            "url": "http://localhost:8000/api/ocr/process"
          }
        },
        {
          "name": "Extract Data",
          "request": {
            "method": "POST",
            "body": {
              "mode": "formdata",
              "formdata": [
                {"key": "file", "type": "file", "src": ""},
                {"key": "document_type", "value": "invoice", "type": "text"}
              ]
            },
            "url": "http://localhost:8000/api/extract"
          }
        },
        {
          "name": "Verify Document",
          "request": {
            "method": "POST",
            "body": {
              "mode": "formdata",
              "formdata": [
                {"key": "file", "type": "file", "src": ""}
              ]
            },
            "url": "http://localhost:8000/api/verify"
          }
        },
        {
          "name": "Batch Verify",
          "request": {
            "method": "POST",
            "body": {
              "mode": "formdata",
              "formdata": [
                {"key": "files", "type": "file", "src": ""},
                {"key": "files", "type": "file", "src": ""}
              ]
            },
            "url": "http://localhost:8000/api/verify/batch"
          }
        }
      ]
    },
