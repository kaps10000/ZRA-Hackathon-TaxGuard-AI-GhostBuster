# Blockchain Configuration
# Copy this file to .env and add your actual values

# Network Configuration
GANACHE_URL=http://127.0.0.1:8545
HARDHAT_NETWORK=localhost

# Test Account Private Keys (DO NOT use in production)
# These will be generated when you run Ganache
PRIVATE_KEY=

# Account roles for testing
ZRA_OFFICER_KEY=
AUDITOR_KEY=
DEVELOPER_KEY=

# Gas Configuration
GAS_LIMIT=6000000
GAS_PRICE=20000000000

# Optional: For production deployment
# INFURA_API_KEY=
# ALCHEMY_API_KEY=
