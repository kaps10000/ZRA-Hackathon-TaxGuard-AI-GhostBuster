        {
          "name": "1. Verify Complete Document",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status code is 200', function () {",
                  "    pm.response.to.have.status(200);",
                  "});",
                  "pm.test('Has verification result', function () {",
                  "    pm.expect(pm.response.json()).to.have.property('verification');",
                  "});",
                  "pm.test('Has verification status', function () {",
                  "    const json = pm.response.json();",
                  "    pm.expect(json.verification).to.have.property('status');",
                  "});",
                  "pm.test('Has risk flags', function () {",
                  "    const json = pm.response.json();",
                  "    pm.expect(json.verification).to.have.property('riskFlags');",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"extractedData\": {\n    \"invoiceNumber\": \"INV-2025-12345\",\n    \"importerName\": \"ABC Technology Corporation\",\n    \"hsCode\": \"8471.30.00\",\n    \"totalValue\": 112500,\n    \"quantity\": 250,\n    \"unitPrice\": 450,\n    \"currency\": \"USD\",\n    \"originCountry\": \"China\",\n    \"declarationId\": \"DECL-ZM-2025-789\"\n  }\n}"
            },
            "url": {
              "raw": "http://localhost:3000/api/verification/document",
              "protocol": "http",
              "host": ["localhost"],
              "port": "3000",
              "path": ["api", "verification", "document"]
            },
            "description": "Comprehensive document verification with all extracted data"
          },
          "response": []
