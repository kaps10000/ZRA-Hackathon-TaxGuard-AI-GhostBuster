{
  "name": "taxguard-blockchain",
  "version": "1.0.0",
  "description": "Blockchain module for TaxGuard AI - Hyperledger Fabric implementation",
  "main": "api/index.js",
  "scripts": {
    "start": "node api/index.js",
    "dev": "nodemon api/index.js",
    "test": "jest",
    "test:watch": "jest --watch",
    "docker:build": "docker build -t taxguard-blockchain .",
    "docker:run": "docker run -p 3001:3001 taxguard-blockchain",
    "docker:compose": "docker-compose -f config/docker-compose.yml up -d",
    "multi-node": "node scripts/multi-node.js",
    "deploy": "node scripts/deploy.js",
    "network-up": "docker-compose -f config/docker-compose.yml up -d",
    "network-down": "docker-compose -f config/docker-compose.yml down"
  },
  "dependencies": {
    "bcrypt": "^6.0.0",
    "crypto": "^1.0.1",
    "express": "^4.18.0",
    "fabric-ca-client": "^2.2.0",
    "fabric-network": "^2.2.0",
    "socket.io": "^4.8.1",
    "swagger-jsdoc": "^6.2.8",
    "swagger-ui-express": "^5.0.1",
    "uuid": "^9.0.0"
  },
  "devDependencies": {
    "jest": "^29.7.0",
    "nodemon": "^2.0.22",
    "supertest": "^7.1.4"
  },
  "author": "Kaps (Dev 4)",
  "license": "MIT"
}
