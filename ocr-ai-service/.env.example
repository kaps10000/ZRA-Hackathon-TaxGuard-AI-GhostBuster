# =====================================================
# ZRA TaxGuard OCR AI Service - Environment Variables
# =====================================================

# Application Settings
APP_NAME="ZRA TaxGuard OCR AI Service"
VERSION="1.0.0"
DEBUG=false
PORT=8000

# CORS Settings (comma-separated)
ALLOWED_ORIGINS="http://localhost:3000,http://localhost:5000,http://localhost:8080"

# OCR Settings
TESSERACT_PATH="/usr/bin/tesseract"
TESSERACT_LANG="eng"
OCR_DPI=300
OCR_PSM=3

# Image Preprocessing
ENABLE_PREPROCESSING=true
PREPROCESSING_RESIZE=true
PREPROCESSING_DENOISE=true
PREPROCESSING_THRESHOLD=true

# Google Vision API (Optional - for premium OCR)
USE_GOOGLE_VISION=false
GOOGLE_APPLICATION_CREDENTIALS=""

# File Upload Settings
MAX_FILE_SIZE=10485760  # 10MB in bytes
UPLOAD_DIR="/app/uploads"
TEMP_DIR="/app/temp"

# Database Settings
DB_HOST="postgres"
DB_PORT=5432
DB_NAME="zra_taxguard"
DB_USER="postgres"
DB_PASSWORD="zrapassword"

# Backend Integration
BACKEND_URL="http://ocr-backend:5000"
BLOCKCHAIN_URL="http://blockchain-service:3001"

# AI/NLP Settings
SPACY_MODEL="en_core_web_sm"
NLP_BATCH_SIZE=50

# Field Extraction Confidence Thresholds
MIN_FIELD_CONFIDENCE=0.7
MIN_DATE_CONFIDENCE=0.8
MIN_AMOUNT_CONFIDENCE=0.85

# Risk Scoring Thresholds
RISK_LOW_THRESHOLD=70.0
RISK_MEDIUM_THRESHOLD=50.0
RISK_HIGH_THRESHOLD=30.0

# Anomaly Detection
ENABLE_ANOMALY_DETECTION=true
ANOMALY_DETECTION_STRICT=false

# Performance Settings
WORKER_THREADS=4
MAX_CONCURRENT_REQUESTS=10
REQUEST_TIMEOUT=60

# Logging
LOG_LEVEL="INFO"
LOG_FILE="/app/logs/ocr-ai-service.log"
LOG_ROTATION="100 MB"
LOG_RETENTION="30 days"

# Security
API_KEY_ENABLED=false
API_KEY=""
